    "a8328974-ef07-4aca-8fb0-1a5847b717f7": {
      "id": "a8328974-ef07-4aca-8fb0-1a5847b717f7",
      "tags": {
        "casualTutorial": true,
        "color": "#3e82f8",
        "homeX": -2,
        "homeY": -4,
        "name": "mover",
        "onBotChanged": "@if (!that.tags.includes(\"home\")) return;\n\nif (!tags.home) { // Stop listening if not home\n    setTagMask(thisBot, \"onKeyDown\", null, \"local\")\n\n} else { // Reset location & start listening if home\n    tags.homeX = -2\n    tags.homeY = -4\n\n    setTagMask(thisBot, \"onKeyDown\",\n`@if (that.keys.includes(\"ArrowDown\")) {\n    tags.homeY = tags.homeY - 1\n}\n\nif (that.keys.includes(\"ArrowUp\")) {\n    tags.homeY = tags.homeY + 1\n}\n\nif (that.keys.includes(\"ArrowLeft\")) {\n    tags.homeX = tags.homeX - 1\n}\n\nif (that.keys.includes(\"ArrowRight\")) {\n    tags.homeX = tags.homeX + 1\n}`,\n    \"local\"\n    )\n}",
        "sequence": "interactions",
        "step": 3,
        "abIDStudio": "62435408-dd5d-4856-a29c-ef4eb04f7fee",
        "abVersion": "9.65.1.1728866444854"
      }
    },
