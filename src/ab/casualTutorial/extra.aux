        "onPortalChanged": "@if (!tags.home) return\n\nif (that.portal == 'gridPortal') {\n    if (that.dimension != 'home') {\n        setTagMask(thisBot, 'moved', true, 'tempLocal')\n    } else if (tags.moved && !tags.spoke) {\n        shout('executeDialogue', {sequence: 'portals', step: 3, dialogueIndex: 4})\n        setTagMask(thisBot, 'spoke', true, 'tempLocal')\n    }\n}",
