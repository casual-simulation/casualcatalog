        "name": "blue",
        "onClick": "@// Open the sheet portal\nconfigBot.tags.sheetPortal = thisBot.id\n\n// Limit the tags that are shown, to not clutter the page\nsheetPortalBot.tags.sheetPortalAllowedTags = ['onClick', 'homeX', 'homeY', 'color', 'scale', 'scaleX', 'scaleY', 'scaleZ']\n",
        "onPortalChanged": "@if (that.portal == 'sheetPortal'        // Make sure it was the sheet portal\n    && !that.dimension                  // Check that it was closed\n    && tags.color !== 'royalblue') {    // Make sure color was changed\n\n        shout('executeDialogue', {\n            sequence: 'portals',\n            step: 1,\n            dialogueIndex: 4\n        })\n\n}",
