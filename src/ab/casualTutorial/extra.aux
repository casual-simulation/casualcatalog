    "925d03b9-5f04-46d2-a1d8-8f94e3c36492": {
      "id": "925d03b9-5f04-46d2-a1d8-8f94e3c36492",
      "tags": {
        "casualTutorial": true,
        "bounce": "@if (!tags.home) return\n\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: 0,\n    toValue: 2,\n    duration: 2,\n    easing: {\n        type: 'elastic',\n        mode: 'in'\n    }\n})\n\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: 2,\n    toValue: 0,\n    duration: 0.5,\n    easing: {\n        type: 'quadratic',\n        mode: 'in'\n    }\n})\n\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: 0,\n    toValue: 1,\n    duration: 0.5,\n    easing: {\n        type: 'quadratic',\n        mode: 'out'\n    }\n})\n\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: 1,\n    toValue: 0,\n    duration: 0.5,\n    easing: {\n        type: 'quadratic',\n        mode: 'in'\n    }\n})",
        "changeColor": "@if (!tags.home) return\n\nvar randomColor = tags.colors[Math.floor(Math.random() * tags.colors.length)]\nmasks.color = randomColor",
        "color": "#9061f9",
        "colors": "🧬[\"#f8b4d9\", \"#f17eb8\", \"#e64694\", \"#d61f69\", \"#bf125d\",\n\"#f8b4b3\", \"#f87f7f\", \"#f05152\", \"#e02423\", \"#c81e1d\",\n\"#fdba8c\", \"#ff8a4c\", \"#ff5a1f\", \"#d03800\", \"#b43403\",\n\"#f9ca16\", \"#e3a008\", \"#c27701\", \"#9e580b\", \"#8e4a10\",\n\"#83e1bc\", \"#30c48d\", \"#0b9f6e\", \"#047a55\", \"#036b4e\",\n\"#7edce1\", \"#17bdca\", \"#0694a2\", \"#047481\", \"#036572\",\n\"#a4cafd\", \"#76a9fa\", \"#3e82f8\", \"#1b64f1\", \"#1a56db\",\n\"#b3c5fc\", \"#8da1fb\", \"#6775f5\", \"#5850eb\", \"#5144cc\",\n\"#cabefc\", \"#ac94fa\", \"#9061f9\", \"#7d3af2\", \"#6c2bd9\"]",
        "draggable": "false",
        "homeX": -1,
        "homeY": 2,
        "jump": "@if (!tags.home) return\n\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: 0,\n    toValue: 2,\n    duration: 0.3,\n    easing: {\n        type: 'quadratic',\n        mode: 'out'\n    }\n})\n\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: 2,\n    toValue: 0,\n    duration: 0.3,\n    easing: {\n        type: 'quadratic',\n        mode: 'in'\n    }\n})",
        "name": "mover",
        "sequence": "shoutListen",
        "slide": "@if (!tags.home) return\n\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: 0,\n    toValue: 0.5,\n    duration: 0.125,\n    easing: {\n        type: 'quadratic',\n        mode: 'out'\n    }\n})\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: 0.5,\n    toValue: 0,\n    duration: 0.125,\n    easing: {\n        type: 'quadratic',\n        mode: 'in'\n    }\n})\n\nif (tags.homeX == -1) {\n    await animateTag(thisBot, \"homeX\", {\n        fromValue: -1,\n        toValue: -4,\n        duration: 1,\n        easing: {\n            type: 'exponential',\n            mode: 'out'\n        }\n    })\n} else {\n    await animateTag(thisBot, \"homeX\", {\n        fromValue: -4,\n        toValue: -1,\n        duration: 1,\n        easing: {\n            type: 'exponential',\n            mode: 'out'\n        }\n    })\n}",
        "spin": "@if (!tags.home) return\n\nawait animateTag(thisBot, \"homeRotationZ\", {\n    fromValue: 0,\n    toValue: 3.14159,\n    duration: 0.5,\n    easing: {\n        type: 'cubic',\n        mode: 'in'\n    }\n})\n\nawait animateTag(thisBot, \"homeRotationZ\", {\n    fromValue: 3.14159,\n    toValue: 6.28318,\n    duration: 2,\n    easing: {\n        type: 'elastic',\n        mode: 'out'\n    }\n})\n",
        "step": 3,
        "abIDStudio": "62435408-dd5d-4856-a29c-ef4eb04f7fee",
        "abVersion": "9.65.1.1728866444854"
      }
    },
