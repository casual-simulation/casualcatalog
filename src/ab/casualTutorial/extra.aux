    "3aad8f33-83af-4148-a88a-3092b6cd0a4b": {
      "id": "3aad8f33-83af-4148-a88a-3092b6cd0a4b",
      "tags": {
        "casualTutorial": true,
        "color": "#0b9f6e",
        "draggable": "false",
        "goHome": "@await os.closeCircleWipe()\nos.goToDimension('home')\n// Grid portal is updated in system.dimensionManager\n\n// Update this bot\nsetTagMask(thisBot, 'floating', false, 'local')\nsetTagMask(thisBot, 'color', '#0b9f6e', 'local')\n\nawait os.sleep(250)\nshout('executeDialogue', {sequence: 'portals', step: '2', dialogueIndex: 6, dimension: 'home', id: thisBot.id})\nawait os.openCircleWipe()",
        "goToSpace": "@if (os.getCurrentDimension() == 'outerSpace') return\n\nawait os.closeCircleWipe()\nos.goToDimension('outerSpace')\n// Styling of grid portal handled in system.dimensionManager\n\n// Update this bot\nif (!tags.floating) {\n    whisper(thisBot, 'startFloat')\n    setTagMask(thisBot, 'floating', true, 'local')\n}\nsetTagMask(thisBot, 'color', '#047a55', 'local')\n\n\nawait os.sleep(250);\nawait os.openCircleWipe();\nos.sleep(300).then(() => shout('executeDialogue', {sequence: 'portals', step: '2', dialogueIndex: 1, id: thisBot.id}) )\n",
        "homeX": 0,
        "homeY": 1,
        "name": "green",
        "onBotChanged": "@if (that.tags.includes('home') && tags.home) {\n    whisper(thisBot, 'goToSpace')\n}",
        "onClick": "@if (os.getCurrentDimension() != 'home' && stepManager.tags.step == 2) {\n    shout('hideSpeechBubble')\n    whisper(thisBot, 'goHome')\n}\n",
        "outerSpace": "true",
        "sequence": "portals",
        "startFloat": "@await animateTag(thisBot, \"outerSpaceZ\", {\n    fromValue: 0,\n    toValue: -1,\n    duration: 3,\n    easing: 'sinusoidal',\n})\n\nawait animateTag(thisBot, \"outerSpaceZ\", {\n    fromValue: -1,\n    toValue: 0,\n    duration: 3,\n    easing: 'sinusoidal',\n})\n\nif (tags.floating) {\n    whisper(thisBot, 'startFloat')\n}",
        "step": "2",
        "abIDStudio": "62435408-dd5d-4856-a29c-ef4eb04f7fee",
        "abVersion": "9.65.1.1728866444854"
      }
    },
