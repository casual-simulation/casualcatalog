    "a6f743e6-3955-4b42-a4dd-fac26aee9768": {
      "id": "a6f743e6-3955-4b42-a4dd-fac26aee9768",
      "tags": {
        "casualTutorial": true,
        "color": "#17bdca",
        "homeX": -4,
        "homeY": 5,
        "name": "teal",
        "onAnyCreate": "@if (!tags.home) return;\n\nif (that.bot.tags.form == 'sprite') {\n    // Make that bot open its #formAddress tag when clicked\n    that.bot.tags.onClick = `@\n    shout('openTagPortal', {id: thisBot.id, tag: 'formAddress'});\n    configBot.tags.codeToolsPortal = 'help';\n`\n    that.bot.tags.scale = 3\n    // Say the next dialogue part\n    shout('executeDialogue', {sequence: 1, step: 8, dialogueIndex: 3})\n}",
        "sequence": "introDeep",
        "step": "2",
        "abIDStudio": "62435408-dd5d-4856-a29c-ef4eb04f7fee",
        "abVersion": "9.65.1.1728866444854"
