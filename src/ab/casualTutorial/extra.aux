    "a12c1af7-40d8-4682-9094-349cceba4a60": {
      "id": "a12c1af7-40d8-4682-9094-349cceba4a60",
      "tags": {
        "casualTutorial": true,
        "color": "clear",
        "homeX": "0",
        "homeY": "0",
        "name": "ab1Proxy",
        "onAnyCreate": "@if (!tags.home) return\n\nif (that.bot.tags.onClick || that.bot.tags.ab1Click) return\n\nif (tags.beenToSheet && !tags.addedBot) {\n    setTagMask(thisBot, 'addedBot', true, 'local')\n    shout('executeDialogue', {sequence: 'portals', step: 4, dialogueIndex: 6})\n}\n",
        "onPortalChanged": "@if (!tags.home) return\n\nif (that.portal == 'sheetPortal' && !tags.beenToSheet) {\n    setTagMask(thisBot, 'beenToSheet', true, 'local')\n    shout('executeDialogue', {sequence: 'portals', step: 4, dialogueIndex: 5})\n}\n",
