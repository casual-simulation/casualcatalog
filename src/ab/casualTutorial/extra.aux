        "jump": "@await os.sleep(tags.delay)\n\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: tags.homeZ,\n    toValue: tags.homeZ == 0 ? 2 : 0,\n    duration: 0.25,\n    easing: {\n        type: \"quadratic\",\n        mode: \"out\"\n    }\n})\n\nawait animateTag(thisBot, \"homeZ\", {\n    fromValue: tags.homeZ,\n    toValue: tags.homeZ == 0 ? 2 : 0,\n    duration: 0.25,\n    easing: {\n        type: \"quadratic\",\n        mode: \"in\"\n    }\n})",
        "sequence": "shoutListen",
        "slide": "@await os.sleep(tags.delay)\n\nawait animateTag(thisBot, \"homeY\", {\n    fromValue: tags.homeY,\n    toValue: tags.homeY == tags.startY ? tags.startY + 1 : tags.startY,\n    duration: 0.25,\n})",
