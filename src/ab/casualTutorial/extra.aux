        "step": 1,
        "turn": "@await os.sleep(tags.delay)\n\nawait animateTag(thisBot, \"homeRotationZ\", {\n    fromValue: tags.homeRotationZ,\n    toValue: tags.homeRotationZ == 0 ? 2 : 0,\n    duration: 0.25,\n})",
