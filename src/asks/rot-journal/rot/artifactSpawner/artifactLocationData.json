      "Artifact": {
        "data": {
          "id": 9,
          "attributes": {
            "Name": "Limestone",
            "Description": "Limestone is a sedimentary rock that often forms in warm, shallow marine water. It is made of mostly calcium carbonate and can be white, gray, or pink in color. This specimen is gray and has been cut into a slab, likely to be used in the construction of a limestone building.",
